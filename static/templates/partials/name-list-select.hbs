<div class="name-list droppable {{classes}}" data-path="{{path}}">
    <label>{{localize label}}</label>
    <div class="list-content">
        {{#each list}}
            <div class="list-element input" data-index="{{@key}}">
                <select type="text" data-action="editList">
                    {{selectOptions ../options selected=this}}
                </select>
                <a class="floating" data-document="this" data-action="listDelete" ><i class="fa-solid fa-xmark"></i></a>
            </div>
        {{/each}}
        <div class="list-element input" data-index="{{@key}}">
            <select type="text" class="empty" data-action="listCreateValue">
                {{selectOptions options blank="+"}}
            </select>
        </div>
    </div>
</div>